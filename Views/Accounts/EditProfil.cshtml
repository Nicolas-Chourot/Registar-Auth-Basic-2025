@model JsonDemo.Models.User
@{
    ViewBag.Title = "Modification de profil";
}
<form method='post' action='/Accounts/EditProfil' class="profil-form">
    @Html.AntiForgeryToken()
    <fieldset>
        <legend>Adresse ce courriel</legend>
        <input type="email"
               class="form-control Email"
               name="Email"
               id="Email"
               placeholder="Courriel"
               required
               RequireMessage='Veuillez entrer votre courriel'
               InvalidMessage='Courriel invalide'
               CustomErrorMessage="Ce courriel est déjà utilisé"
               value="@Model.Email">

        <input class="form-control MatchedInput"
               type="text"
               matchedInputId="Email"
               name="matchedEmail"
               id="matchedEmail"
               placeholder="Vérification"
               required
               RequireMessage='Veuillez entrez de nouveau votre courriel'
               InvalidMessage="Les courriels ne correspondent pas"
               value="@Model.Email">
    </fieldset>
    <fieldset>
        <legend>Mot de passe</legend>
        <input type="password"
               class="form-control"
               name="Password"
               id="Password"
               placeholder="Mot de passe"
               InvalidMessage='Mot de passe trop court'>

        <input class="form-control MatchedInput"
               type="password"
               matchedInputId="Password"
               name="matchedPassword"
               id="matchedPassword"
               placeholder="Vérification"
               InvalidMessage="Ne correspond pas au mot de passe">
    </fieldset>
    <fieldset>
        <legend>Nom</legend>
        <input type="text"
               class="form-control Alpha"
               name="Name"
               id="Name"
               placeholder="Nom"
               required
               RequireMessage='Veuillez entrer votre nom'
               InvalidMessage='Nom invalide'
               value="@Model.Name">
    </fieldset>
    <fieldset>
        <legend>Avatar</legend>
        @Helper.ImageUploader("Avatar", Model.Avatar, "Cliquez glisser une photo")
    </fieldset>
    <hr>
    @Helper.ButtonConfirmCmd("/Accounts/DeleteProfil", "form-control btn btn-danger", "Effacer mon compte", "Voulez-vous vraiment effacer votre compte et toutes vos photos?")
    <br/>
</form>

@section Scripts {
    @Scripts.Render("~/bundles/customval")
    <script>
        initFormValidation();
        addConflictValidation('/Accounts/EmailConflict', 'Email', 'updateProfil-submit-btn');
    </script>
}

